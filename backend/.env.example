# ── App ──────────────────────────────────────────────────
APP_NAME=CodeLens AI
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# ── Server ───────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
FRONTEND_URL=http://localhost:3000

# ── Database (PostgreSQL + pgvector) ─────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/codelens
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/codelens

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── GitHub OAuth ─────────────────────────────────────────
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:3000/auth/callback

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Gemini AI ────────────────────────────────────────────
# Get at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# ── Encryption ───────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_fernet_key_here
